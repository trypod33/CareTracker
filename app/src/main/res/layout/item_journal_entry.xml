<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_dark"
    android:padding="14dp"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">
        <TextView android:id="@+id/tvJournalDate"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="12sp" android:textColor="#777777"/>
        <TextView android:id="@+id/tvJournalMood"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="18sp"/>
    </LinearLayout>

    <TextView android:id="@+id/tvJournalContent"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="14sp" android:textColor="#cccccc"
        android:maxLines="3" android:ellipsize="end"/>

    <TextView android:id="@+id/tvJournalTags"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="11sp" android:textColor="#8db87a" android:layout_marginTop="6dp"
        android:visibility="gone"/>
</LinearLayout>
