<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Backup &amp; Restore"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Export your data to a JSON file in Downloads. Restore from any previous backup."
            android:textColor="#AAAAAA"
            android:textSize="14sp" />

        <!-- Status card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="#1E1E1E"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvLastBackup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No backup created yet"
                android:textColor="#B0B0B0"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvBackupStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text=""
                android:textColor="#4f9cf9"
                android:textSize="13sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnExportBackup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:backgroundTint="#4f9cf9"
            android:padding="14dp"
            android:text="📤  Export Backup to Downloads"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnRestoreBackup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="#2C2C2C"
            android:padding="14dp"
            android:text="📥  Restore from Backup File"
            android:textColor="#CCCCCC"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="#2A1500"
            android:padding="12dp"
            android:text="⚠️  Restoring will replace all data for this user. This cannot be undone."
            android:textColor="#FFB74D"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="#1E1E1E"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="What's included"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp"
                android:text="• Habits &amp; habit logs
• Medications &amp; dose logs
• Tasks
• Health entries &amp; vitals
• Mood journal
• Calendar events

Passwords are stored in hashed form only and are never recoverable in plain text."
                android:textColor="#AAAAAA"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
