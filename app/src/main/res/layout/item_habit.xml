<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="14dp"
    android:background="@drawable/bg_habit_item"
    android:layout_marginBottom="10dp"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/tvHabitIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="✨"
        android:textSize="20sp"
        android:textColor="#ffffff"
        android:background="@drawable/bg_toggle_unchecked"
        android:layout_marginEnd="12dp"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvHabitName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="#ffffff"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvHabitStreak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#d9a441"
            android:layout_marginTop="3dp"/>

        <TextView
            android:id="@+id/tvHabitCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/btnHabitEdit"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:gravity="center"
        android:text="⋮"
        android:textSize="18sp"
        android:textColor="#d0d0d0"
        android:layout_marginEnd="8dp"/>

    <TextView
        android:id="@+id/tvToggle"
        android:layout_width="54dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="+"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#111811"
        android:background="@drawable/bg_toggle_checked"
        android:layout_marginEnd="8dp"/>

    <TextView
        android:id="@+id/btnDrag"
        android:layout_width="28dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="≡"
        android:textSize="20sp"
        android:textColor="#777777"/>
</LinearLayout>
