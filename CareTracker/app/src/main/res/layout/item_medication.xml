<?xml version="1.0" encoding="utf-8"?>
<!--
    Medication display card — matches dark-themed mockup:
    • Colored pill icon + name + action icons row
    • 2-column meta grid (Dosage, Form, Frequency, Prescriber)
    • Pill Inventory section with progress bar
    • "Not taken today" status + Take / Refill buttons
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="?attr/colorSurfaceVariant">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Header: icon + name + person + action buttons ────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <!-- Pill icon badge -->
            <TextView
                android:id="@+id/tvMedIcon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="💊"
                android:textSize="20sp"
                android:background="@drawable/bg_med_icon"
                android:layout_marginEnd="10dp" />

            <!-- Name + person column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvMedName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:text="Medication Name" />

                <TextView
                    android:id="@+id/tvMedPersonName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:visibility="gone"
                    android:text="" />

            </LinearLayout>

            <!-- Edit button -->
            <ImageButton
                android:id="@+id/btnEditMed"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_edit"
                android:contentDescription="Edit medication"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="?attr/colorOnSurfaceVariant"
                android:layout_marginStart="4dp" />

            <!-- Copy button -->
            <ImageButton
                android:id="@+id/btnCopyMed"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_copy"
                android:contentDescription="Duplicate medication"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="?attr/colorOnSurfaceVariant"
                android:layout_marginStart="4dp" />

            <!-- Delete button -->
            <ImageButton
                android:id="@+id/btnDeleteMed"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_delete"
                android:contentDescription="Delete medication"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/ct_error"
                android:layout_marginStart="4dp" />

        </LinearLayout>

        <!-- ── Divider ─────────────────────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutlineVariant"
            android:layout_marginBottom="10dp" />

        <!-- ── 2-column meta grid ────────────────────────────────────────── -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:layout_marginBottom="12dp">

            <!-- Dosage -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DOSAGE"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:textColor="?attr/colorOnSurfaceVariant" />
                <TextView
                    android:id="@+id/tvMedDosage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:text="—" />
            </LinearLayout>

            <!-- Form -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FORM"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:textColor="?attr/colorOnSurfaceVariant" />
                <TextView
                    android:id="@+id/tvMedForm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:text="—" />
            </LinearLayout>

            <!-- Frequency -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FREQUENCY"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:textColor="?attr/colorOnSurfaceVariant" />
                <TextView
                    android:id="@+id/tvMedFrequency"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:text="—" />
            </LinearLayout>

            <!-- Prescriber -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PRESCRIBER"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:textColor="?attr/colorOnSurfaceVariant" />
                <TextView
                    android:id="@+id/tvMedPrescriber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:text="—" />
            </LinearLayout>

        </GridLayout>

        <!-- ── Pill Inventory section ─────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_inventory_section"
            android:padding="10dp"
            android:layout_marginBottom="10dp">

            <!-- "PILL INVENTORY" label + count badge row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="PILL INVENTORY"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/tvPillCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 pills"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorPrimary"
                    android:background="@drawable/bg_pill_badge"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp" />

            </LinearLayout>

            <!-- Progress bar -->
            <ProgressBar
                android:id="@+id/progressPills"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="50"
                android:progressTint="?attr/colorPrimary"
                android:progressBackgroundTint="?attr/colorSurfaceVariant" />

        </LinearLayout>

        <!-- ── Status + action buttons row ──────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTakenStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Not taken today"
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTakeMed"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Take"
                android:textSize="13sp"
                android:layout_marginStart="8dp"
                app:icon="@drawable/ic_check"
                app:iconSize="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRefillMed"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Refill"
                android:textSize="13sp"
                android:layout_marginStart="8dp"
                app:icon="@drawable/ic_refill"
                app:iconSize="16dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
