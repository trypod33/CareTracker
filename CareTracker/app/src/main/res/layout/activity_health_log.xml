<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="UPDATE HEALTH DATA"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:letterSpacing="0.05"
            android:layout_marginBottom="12dp" />

        <!-- DATE -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="DATE" android:textSize="11sp" android:textStyle="bold"
            android:textColor="?attr/colorOnSurfaceVariant" android:letterSpacing="0.08"
            android:layout_marginBottom="4dp" />
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="true"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ─────────────── BODY MEASUREMENTS ─────────────── -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="💪 BODY MEASUREMENTS"
            android:textSize="12sp" android:textStyle="bold" android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="3"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1.5" android:hint="WEIGHT"
                android:layout_marginEnd="6dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etWeight"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="numberDecimal" />
            </com.google.android.material.textfield.TextInputLayout>

            <Spinner
                android:id="@+id/spinnerWeightUnit"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="0.7"
                android:layout_marginEnd="6dp"
                android:entries="@array/weight_units" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1.3" android:hint="HEART RATE (BPM)"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etHeartRate"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- ─────────────── VITALS ─────────────── -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="❤️ VITALS"
            android:textSize="12sp" android:textStyle="bold" android:textColor="?attr/colorError"
            android:layout_marginBottom="8dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="3"
            android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:hint="BP SYSTOLIC"
                android:layout_marginEnd="6dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etBpSystolic"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="number" /></com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:hint="BP DIASTOLIC"
                android:layout_marginEnd="6dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etBpDiastolic"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="number" /></com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:hint="BLOOD SUGAR"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etBloodSugar"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="numberDecimal" /></com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- BP time / BS time row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="2"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:hint="BP TIME (OPTIONAL)"
                android:layout_marginEnd="6dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etBpTime"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:focusable="false" android:clickable="true" android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:hint="BS TIME (OPTIONAL)"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etBsTime"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:focusable="false" android:clickable="true" android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- ─────────────── SLEEP ─────────────── -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🌙 SLEEP"
            android:textSize="12sp" android:textStyle="bold" android:textColor="?attr/colorTertiary"
            android:layout_marginBottom="8dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="2"
            android:layout_marginBottom="4dp">
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:hint="SLEEP HOURS"
                android:layout_marginEnd="6dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSleepHours"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="numberDecimal" /></com.google.android.material.textfield.TextInputLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SLEEP QUALITY (1-10)" android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
                <SeekBar
                    android:id="@+id/seekSleepQuality"
                    android:layout_width="match_parent" android:layout_height="wrap_content" />
                <TextView
                    android:id="@+id/tvSleepQualityVal"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="None" android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>
        </LinearLayout>

        <!-- padding -->
        <Space android:layout_width="match_parent" android:layout_height="12dp" />

        <!-- ─────────────── WELLNESS ─────────────── -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🌟 WELLNESS"
            android:textSize="12sp" android:textStyle="bold" android:textColor="?attr/colorSecondary"
            android:layout_marginBottom="8dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="2"
            android:layout_marginBottom="16dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:layout_marginEnd="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="MOOD (1-10)" android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
                <SeekBar android:id="@+id/seekMood"
                    android:layout_width="match_parent" android:layout_height="wrap_content" />
                <TextView android:id="@+id/tvMoodVal"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="None" android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ENERGY LEVEL (1-10)" android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
                <SeekBar android:id="@+id/seekEnergy"
                    android:layout_width="match_parent" android:layout_height="wrap_content" />
                <TextView android:id="@+id/tvEnergyVal"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="None" android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

        </LinearLayout>

        <!-- ─────────────── ACTIVITY & NUTRITION ─────────────── -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🏃 ACTIVITY &amp; NUTRITION"
            android:textSize="12sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="8dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="2"
            android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:hint="STEPS"
                android:layout_marginEnd="6dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSteps"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="number" android:hint="e.g. 8000" /></com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:hint="EXERCISE (MINUTES)"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etExercise"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="number" /></com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="2"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:hint="WATER (OZ)"
                android:layout_marginEnd="6dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etWater"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="numberDecimal" /></com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:hint="CALORIES"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCalories"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="number" /></com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- ─────────────── NOTES ─────────────── -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="NOTES"
            android:layout_marginBottom="20dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="3"
                android:gravity="top"
                android:inputType="textMultiLine" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ─────────────── ACTIONS ─────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start">

            <Button
                android:id="@+id/btnSaveHealthLog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💪 Save Entry"
                android:layout_marginEnd="12dp"
                style="@style/Widget.MaterialComponents.Button" />

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancel"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
