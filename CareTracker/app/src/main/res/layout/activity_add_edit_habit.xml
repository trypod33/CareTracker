<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">
        <EditText android:id="@+id/etHabitName" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Habit name" />
        <EditText android:id="@+id/etHabitDescription" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="Description" />
        <EditText android:id="@+id/etHabitFrequency" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="Frequency" />
        <EditText android:id="@+id/etHabitTarget" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="Target" android:inputType="number" />
        <EditText android:id="@+id/etHabitReminder" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="Reminder time" />
        <Button android:id="@+id/btnSaveHabit" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Save Habit" />
    </LinearLayout>
</ScrollView>
